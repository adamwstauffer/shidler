.directory

# IDE and Editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace
*.swp
*.swo

# OS-specific backup files
*~
*.bak
*.tmp

# Sensitive information (never commit credentials)
.env
.env.local
.env.*.local
secrets.json
credentials.json
credentials.yml
config/secrets.yml

# Temporary files
*.log
*.lock

# Compiled/generated files (if any)
*.pyc
__pycache__/
*.class
*.jar
*.o
*.so

# Python virtualenvs and tool caches
.venv/
venv/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Package managers
node_modules/
.bundle/
vendor/

# Build directories
/build/
/dist/
/target/

# Local-only content (student submissions, grading scratch, PII)
ignore-*/
**/ignore/

# Microsoft Office temp/lock files (e.g. ~$MyDoc.pptx while open)
~$*
**/~$*

# Local backup snapshots of master spreadsheets (rollback only, not source)
docs/spreadsheets/_backups/
